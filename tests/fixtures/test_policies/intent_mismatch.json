{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "WritesInReadOnlyContext",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:ListBucket"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AdminActionsInReadContext",
            "Effect": "Allow",
            "Action": [
                "iam:CreateUser",
                "iam:AttachRolePolicy"
            ],
            "Resource": "*"
        }
    ]
}
