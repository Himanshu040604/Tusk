# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/

# Coverage
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Editor / agent caches (any agentic tooling)
.claude/

# Local-only project context — not shipped, owners may keep a private
# copy on disk for personal workflow notes.
CLAUDE.md
FILE_TREE.txt

# Tooling caches (explicit; previously inherited from a global gitignore)
.mypy_cache/
.ruff_cache/
.hypothesis/

# Sub-agent / review scratch reports (parallel review chains write these)
.agent*_report.md

# Loose screenshots in repo root (test captures, demo grabs)
w[0-9]*.png

# OS
.DS_Store
Thumbs.db
nul

# Pytest
.pytest_cache/

# SQLite migration sidecars and backup artifacts (prod_imp.md § 6.3)
*.db.bak
*.db-wal
*.db-shm
*.db.migrate.lock

# Agent state (runtime)
agent_state/

# pytest-benchmark autosave output (U28): if a contributor manually
# invokes ``pytest --benchmark-autosave`` or ``--benchmark-save=<name>``,
# the resulting machine-specific JSON belongs in local-only ignore.
# Sentinel's test_performance.py intentionally uses time.time() rather
# than the benchmark fixture (see test_performance.py:858-861), so
# this directory normally stays empty — the gitignore is defensive.
.benchmarks/

# SQLite databases populated on first run.  Users run
# `sentinel refresh --source policy-sentry --live` (see README
# "Getting started" Step 4) which creates these files locally.
# Tracking the populated corpus would mean a 5.7 MB binary diff
# per refresh AND HMAC signatures derived from the developer's
# local key would not validate on user machines.
data/iam_actions.db
data/resource_inventory.db
data/known_services.json

# Downloaded AWS examples (generated at runtime)
data/aws_examples/

# Intermediate policy_sentry data (source file + per-service conversions)
data/iam-definition-raw.json
data/policy_sentry_converted/

# Docs folder — CODEBASE_MAP.md is locally generated by cartographer;
# docs/plans/ is a local scratchpad.  Specific files we ship are
# whitelisted; cannot use `docs/` directory-ignore because then
# git won't recurse into it to check per-file exceptions.
docs/CODEBASE_MAP.md
docs/plans/

# All .md files except the explicitly-tracked project docs.
*.md
!README.md
!CONTRIBUTING.md
!ARCHITECTURE.md
!CHANGELOG.md
!docs/FEATURES.md
!docs/USAGE.md

# Specific excluded files
verify_phase1.py
verify_phase2.py
verify_bug_fix.py
klarna_task.txt
prompt.txt
work.png

# Owner's uncommitted working files (never commit)
final.png
firebase-debug.log

# Ephemeral log files (firebase debug logs, pytest logs, arbitrary tooling)
*.log
